{
  "name": "instaintrov",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "expo": "~54.0.33",
    "expo-blur": "~14.0.3",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "^57.0.2",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.15.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "eas-cli": "^20.5.1",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start --lan --port 8084",
    "start:offline": "EXPO_OFFLINE=1 expo start --lan --port 8084",
    "start:tunnel": "expo start --tunnel --port 8084",
    "share:tunnel": "expo start --tunnel --port 8084",
    "share:tunnel:v2": "EXPO_UNSTABLE_TUNNEL_V2=1 expo start --tunnel --port 8084",
    "share:tunnel:legacy": "expo start --tunnel --port 8084",
    "share:lan": "expo start --lan --port 8084",
    "dev": "expo start --lan --port 8084 --clear",
    "start:online": "expo start --lan --port 8084",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export -p web && node scripts/prepare-web-dist.mjs",
    "deploy:web": "npm run build:web && ./workers/innerly-api/node_modules/.bin/wrangler pages deploy dist --project-name=innerly --commit-dirty=true",
    "build:android": "eas build --platform android --profile preview",
    "invite": "node scripts/print-invite.mjs",
    "worker:install": "npm install --prefix workers/innerly-api",
    "worker:dev": "npm run dev --prefix workers/innerly-api",
    "worker:deploy": "npm run deploy --prefix workers/innerly-api",
    "worker:ping": "node scripts/ping-api.mjs",
    "build:ios": "eas build --platform ios --profile preview",
    "build:all": "eas build --platform all --profile preview",
    "update:preview": "eas update --branch preview --message \"dev update\""
  },
  "private": true
}
